# DINO-RICHUP Environment Configuration
# Copy this file to .env and customize as needed

# Secret key for HMAC session tokens (change in production!)
DINO_SECRET_KEY=change-me-to-a-random-string

# Environment: "production" enforces non-empty secret key
# DINO_ENV=development

# CORS origins (comma-separated, or * for all)
DINO_CORS_ORIGINS=*

# Log level: DEBUG, INFO, WARNING, ERROR
DINO_LOG_LEVEL=INFO
