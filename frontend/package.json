{
  "name": "dino-richup-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "codegen": "python ../backend/scripts/codegen.py",
    "dev": "npm run codegen && vite",
    "typecheck": "tsc --noEmit",
    "build": "node scripts/check-schemas.cjs || npm run codegen && tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "framer-motion": "^10.16.4",
    "lucide-react": "^1.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.15.1",
    "socket.io-client": "^4.7.2",
    "zustand": "^4.4.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vitest": "^2.1.3"
  }
}
